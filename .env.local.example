NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ScholarshipOwl Business API (https://api.business.scholarshipowl.com). Used by cron sync and apply.
SCHOLARSHIP_OWL_API_KEY=your-scholarship-owl-api-key

# Optional: custom scholarship JSON API for cron sync (array or { data: [] } of scholarships).
# SCHOLARSHIP_API_URL=https://example.com/scholarships.json
# SCHOLARSHIP_API_KEY=optional-bearer-or-x-api-key

# Cron secret for /api/cron/sync-scholarships (Bearer token or ?secret=).
# CRON_SECRET=your-cron-secret
